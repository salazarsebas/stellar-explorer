direction: right

stellar: Stellar Network {
  style: {
    fill: "#fff3bf"
    stroke: "#e67700"
  }
}

s3: S3 Data Lake {
  style: {
    fill: "#fff3bf"
    stroke: "#e67700"
  }
}

indexer: Go Indexer {
  style: {
    fill: "#e7f5ff"
    stroke: "#1971c2"
  }
  live: Live Ingestion
  backfill: Backfill
}

stores: Data Stores {
  style: {
    fill: "#f8f9fa"
    stroke: "#495057"
  }
  pg: "PostgreSQL\n+ TimescaleDB"
  redis: Redis
  typesense: Typesense
}

stellar -> indexer.live: "~1 ledger / 5s"
stellar -> indexer.backfill: RPC Backfill
s3 -> indexer.backfill: "S3 Backfill\n(pubnet only)"
indexer -> stores.pg: Store
indexer -> stores.redis: Publish
indexer -> stores.typesense: Index
