direction: right

stellar: Stellar Network {
  style: {
    fill: "#fff3bf"
    stroke: "#e67700"
  }
  horizon: Horizon API
  rpc: Soroban RPC
}

client: "client.ts" {
  style: {
    fill: "#e7f5ff"
    stroke: "#1971c2"
  }
  horizon_client: getHorizonClient()
  rpc_client: getRpcClient()
}

queries: "queries.ts" {
  style: {
    fill: "#e7f5ff"
    stroke: "#1971c2"
  }
  keys: stellarKeys
  options: stellarQueries
}

hooks: Custom Hooks {
  style: {
    fill: "#e7f5ff"
    stroke: "#1971c2"
  }
  query: useStellarQuery
  stream: useStreaming
}

components: React Components {
  style: {
    fill: "#f8f9fa"
    stroke: "#495057"
  }
}

stellar.horizon -> client.horizon_client: HTTP
stellar.rpc -> client.rpc_client: JSON-RPC
client -> queries: Cached clients
queries -> hooks: Query options
hooks -> components: Data + loading state
