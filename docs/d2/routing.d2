direction: down

root: "src/app/" {
  style: {
    fill: "#f8f9fa"
    stroke: "#495057"
  }
}

locale: "[locale]" {
  style: {
    fill: "#e7f5ff"
    stroke: "#1971c2"
  }
  note: "en, es, pt, fr, de, zh, ja, ko, it"
}

network: "[network]" {
  style: {
    fill: "#fff3bf"
    stroke: "#e67700"
  }
  note: "public, testnet, futurenet"
}

explorer: "(explorer)" {
  style: {
    fill: "#f8f9fa"
    stroke: "#495057"
  }
  pages: Pages {
    tx: transactions
    ledgers: ledgers
    accounts: accounts
    assets: assets
    contracts: contracts
    search: search
    watchlist: watchlist
  }
}

example: "/en/public/tx/abc123" {
  style: {
    fill: "#d3f9d8"
    stroke: "#2b8a3e"
    font-color: "#2b8a3e"
  }
}

root -> locale
locale -> network
network -> explorer
explorer -> example: "Example URL"
